@model IEnumerable<PatientReports.Models.TransplantEventReportViewModel>
@{
    ViewData["Title"] = "Transplant Event Report";
}

<h2 class="mb-4">Transplant Event Report</h2>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Patient</th>
            <th>Date of Visit</th>
            <th>Date of Previous Visit</th>
            <th>Transplant Date</th>
            <th>Infusion Date</th>
            <th>Event ID</th>
            <th>Inpatient</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.PatientName</td>
                <td>@item.DateOfVisit.ToShortDateString()</td>
                <td>@item.DateOfPreviousVisit.ToShortDateString()</td>
                <td>@item.TransplantDate.ToShortDateString()</td>
                <td>@item.InfusionDate.ToShortDateString()</td>
                <td>@item.EventId</td>
                <td>@item.IsInpatient</td>
            </tr>
        }
    </tbody>
</table>
