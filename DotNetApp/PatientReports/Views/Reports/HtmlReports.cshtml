@model PatientReports.Models.ReportsHubViewModel
@{
    ViewData["Title"] = "HTML Reports";
}

<h2 class="mb-1">HTML-based Reports</h2>
<p class="text-muted">Rendered from the plugin-generated static HTML templates, populated by the existing .NET data logic &mdash; the SSRS replacement.</p>

<form method="get" asp-action="HtmlReports" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label for="report" class="form-label fw-semibold">Report</label>
        <select id="report" name="report" class="form-select">
            <option value="">-- Select a report --</option>
            @foreach (var (value, label) in PatientReports.Models.ReportsHubViewModel.AvailableReports)
            {
                if (Model.SelectedReport == value)
                {
                    <option value="@value" selected>@label</option>
                }
                else
                {
                    <option value="@value">@label</option>
                }
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Generate HTML Report</button>
    </div>
    @if (!string.IsNullOrEmpty(Model.SelectedReport))
    {
        <div class="col-auto">
            <a class="btn btn-outline-secondary" target="_blank"
               asp-action="HtmlReport" asp-route-report="@Model.SelectedReport">Open in new tab</a>
        </div>
    }
</form>

@if (string.IsNullOrEmpty(Model.SelectedReport))
{
    <div class="alert alert-secondary">Select a report above and click <strong>Generate HTML Report</strong>.</div>
}
else
{
    <div class="border rounded">
        <iframe title="HTML report"
                src="@Url.Action("HtmlReport", "Reports", new { report = Model.SelectedReport })"
                style="width:100%; height:80vh; border:0;"></iframe>
    </div>
}
