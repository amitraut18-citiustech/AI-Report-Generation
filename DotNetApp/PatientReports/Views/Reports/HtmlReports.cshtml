@model PatientReports.Models.ReportsHubViewModel
@{
    ViewData["Title"] = "AI Reports";
}

<h2 class="mb-1">AI-Powered Reports</h2>
<p class="text-muted">Ask a question in plain English, or select a report from the dropdown below.</p>

<form id="askForm" method="get" asp-action="AskReport" class="row g-2 align-items-end mb-3">
    <div class="col-md-6">
        <label for="question" class="form-label fw-semibold">Ask a question</label>
        <input type="text" id="question" name="question" class="form-control"
               placeholder="e.g. Show me patients named Ethan"
               value="@Model.Question" />
    </div>
    <div class="col-auto">
        <button type="submit" name="provider" value="local" class="btn btn-success" id="askBtn">Ask Local AI</button>
    </div>
    <div class="col-auto">
        <button type="submit" name="provider" value="claude" class="btn btn-warning" id="askClaudeBtn"
                title="Sends your question text to the Claude API (never any database rows; report data is anonymized before summarization)">Ask Claude</button>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.DecodedBy))
{
    @if (Model.DecodedBy == "claude_fallback")
    {
        <div class="alert alert-warning d-flex align-items-center py-2 mb-3" role="alert">
            <span class="badge bg-warning text-dark me-2">Claude (fallback)</span>
            <span>The local LLM could not interpret your question, so it was answered by <strong>Claude</strong>.</span>
        </div>
    }
    else if (Model.DecodedBy == "claude")
    {
        <div class="alert alert-warning d-flex align-items-center py-2 mb-3" role="alert">
            <span class="badge bg-warning text-dark me-2">Claude</span>
            <span>This question was answered directly by the <strong>Claude API</strong>.</span>
        </div>
    }
    else
    {
        <div class="alert alert-secondary d-flex align-items-center py-2 mb-3" role="alert">
            <span class="badge bg-secondary me-2">Local LLM</span>
            <span>This question was answered by the local model (Ollama) — no data left this machine.</span>
        </div>
    }
}

@if (Model.AppliedFilters.Any())
{
    <div class="mb-3">
        <span class="text-muted me-2">AI-applied filters:</span>
        @foreach (var f in Model.AppliedFilters)
        {
            var opLabel = f.Operator switch
            {
                "equals" => "=",
                "notEquals" => "!=",
                "contains" => "contains",
                "greaterThan" => ">",
                "greaterThanOrEqual" => ">=",
                "lessThan" => "<",
                "lessThanOrEqual" => "<=",
                _ => f.Operator
            };
            var isSkipped = f.Status == "skipped";
            var badgeClass = isSkipped ? "bg-danger" : "bg-info text-dark";
            var style = isSkipped
                ? "font-size: 0.85rem; text-decoration: line-through;"
                : "font-size: 0.85rem;";
            <span class="badge @badgeClass me-1 px-2 py-1" style="@style"
                  title="@(isSkipped ? "Filter could not be applied" : "Filter applied")">
                @f.Table.@f.Field @opLabel <strong>@f.Value</strong>
            </span>
        }
    </div>
}

@if (!string.IsNullOrEmpty(Model.BrainError))
{
    <div class="alert alert-warning">
        <strong>AI:</strong> @Model.BrainError
    </div>
}

<hr class="my-3" />

<form method="get" asp-action="HtmlReports" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label for="report" class="form-label fw-semibold">Or select a report</label>
        <select id="report" name="report" class="form-select">
            <option value="">-- Select a report --</option>
            @foreach (var (value, label) in PatientReports.Models.ReportsHubViewModel.AvailableReports)
            {
                if (Model.SelectedReport == value)
                {
                    <option value="@value" selected>@label</option>
                }
                else
                {
                    <option value="@value">@label</option>
                }
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Generate Report</button>
    </div>
    @if (!string.IsNullOrEmpty(Model.SelectedReport))
    {
        <div class="col-auto">
            <a class="btn btn-outline-secondary" target="_blank"
               asp-action="HtmlReport" asp-route-report="@Model.SelectedReport"
               asp-route-question="@Model.Question"
               asp-route-spec="@Model.QuerySpecB64">Open in new tab</a>
        </div>
    }
</form>

@if (string.IsNullOrEmpty(Model.SelectedReport))
{
    <div class="alert alert-secondary">Ask a question above or select a report and click <strong>Generate Report</strong>.</div>
}
else
{
    <div class="border rounded">
        <iframe title="HTML report"
                src="@Url.Action("HtmlReport", "Reports", new { report = Model.SelectedReport, question = Model.Question, spec = Model.QuerySpecB64 })"
                style="width:100%; height:80vh; border:0;"></iframe>
    </div>
}

<!-- Full-screen spinner shown while the AI decodes the question (brain call can take several seconds). -->
<div id="askSpinner"
     style="display:none; position:fixed; inset:0; background:rgba(255,255,255,.75); z-index:1080;
            align-items:center; justify-content:center; flex-direction:column;">
    <div class="spinner-border text-success" role="status" style="width:3rem; height:3rem;">
        <span class="visually-hidden">Loading…</span>
    </div>
    <div class="mt-3 fw-semibold text-secondary">Generating report from your question…</div>
</div>

@section Scripts {
<script>
    (function () {
        var form = document.getElementById("askForm");
        if (!form) return;
        form.addEventListener("submit", function (e) {
            var q = document.getElementById("question");
            if (!q || !q.value.trim()) return;           // nothing to ask — no spinner
            var sp = document.getElementById("askSpinner");
            if (sp) sp.style.display = "flex";
            var clicked = (e.submitter && e.submitter.id) || "askBtn";
            // Defer disabling so the clicked button's provider value is still
            // included in the submitted form data.
            setTimeout(function () {
                ["askBtn", "askClaudeBtn"].forEach(function (id) {
                    var btn = document.getElementById(id);
                    if (!btn) return;
                    btn.disabled = true;
                    if (id === clicked) btn.textContent = "Asking…";
                });
            }, 0);
        });
    })();
</script>
}
