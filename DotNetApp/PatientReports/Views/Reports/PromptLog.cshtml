@model PatientReports.Models.PromptLogViewModel
@{
    ViewData["Title"] = "Prompt Log";

    static string RowsTable(List<Dictionary<string, object?>>? rows)
    {
        if (rows == null || rows.Count == 0) return "<div class=\"text-muted small\">—</div>";
        var cols = rows.SelectMany(r => r.Keys).Distinct().ToList();
        var html = new System.Text.StringBuilder();
        html.Append("<div class=\"table-responsive\"><table class=\"table table-sm table-bordered mb-0 small\"><thead><tr>");
        foreach (var c in cols)
            html.Append($"<th>{System.Net.WebUtility.HtmlEncode(c)}</th>");
        html.Append("</tr></thead><tbody>");
        foreach (var r in rows)
        {
            html.Append("<tr>");
            foreach (var c in cols)
            {
                r.TryGetValue(c, out var v);
                html.Append($"<td>{System.Net.WebUtility.HtmlEncode(v?.ToString() ?? "")}</td>");
            }
            html.Append("</tr>");
        }
        html.Append("</tbody></table></div>");
        return html.ToString();
    }

    static string LocalTime(string? iso)
    {
        if (DateTimeOffset.TryParse(iso, out var dto))
            return dto.ToLocalTime().ToString("HH:mm:ss");
        return iso ?? "";
    }
}

<h2 class="mb-1">Prompt Log</h2>
<p class="text-muted">
    What was <strong>actually sent</strong> to each LLM for your recent questions — the PHI
    anonymization pipeline, shown live. Ask a question on the AI Reports page, then refresh here.
    The log is in-memory and clears when the brain restarts; nothing here leaves this machine.
</p>

<div class="mb-3 d-flex gap-2">
    <a class="btn btn-outline-primary btn-sm" asp-action="PromptLog">Refresh</a>
    <a class="btn btn-outline-secondary btn-sm" asp-action="HtmlReports">← Ask a question</a>
</div>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-warning">@Model.Error</div>
}
else if (Model.Entries.Count == 0)
{
    <div class="alert alert-secondary">
        No prompts logged yet. Go to <a asp-action="HtmlReports">AI Reports</a> and click
        <strong>Ask Local AI</strong> or <strong>Ask Claude</strong> — every LLM call will appear here.
    </div>
}

@{
    // Group entries into "asks": entries are newest-first, and a decode entry
    // is chronologically the first event of an ask — so it closes a group.
    // Each group = [summarize entries...] + their decode. Only the newest
    // group renders expanded; older asks collapse into accordion items.
    var groups = new List<List<PatientReports.Models.PromptLogEntry>>();
    var current = new List<PatientReports.Models.PromptLogEntry>();
    foreach (var entry in Model.Entries)
    {
        current.Add(entry);
        if (entry.Kind == "decode")
        {
            groups.Add(current);
            current = new List<PatientReports.Models.PromptLogEntry>();
        }
    }
    if (current.Count > 0) { groups.Add(current); }
}

<div class="accordion" id="promptLogAccordion">
@for (var g = 0; g < groups.Count; g++)
{
    var group = groups[g];
    var decode = group.LastOrDefault(x => x.Kind == "decode");
    var headQuestion = decode?.SentQuestion
        ?? group.Select(x => x.OriginalQuestion).FirstOrDefault(q => !string.IsNullOrEmpty(q))
        ?? "(question unavailable)";
    var headButton = decode == null ? null : (decode.Provider == "claude" ? "Ask Claude" : "Ask Local AI");
    var headTime = LocalTime(group[0].Timestamp);
    var expanded = g == 0;

    <div class="accordion-item mb-2 border rounded">
        <h2 class="accordion-header">
            <button class="accordion-button @(expanded ? "" : "collapsed") py-2" type="button"
                    data-bs-toggle="collapse" data-bs-target="#askGroup@(g)">
                <span class="me-2 text-truncate" style="max-width: 50%">&ldquo;@headQuestion&rdquo;</span>
                @if (headButton != null)
                {
                    <span class="badge @(headButton == "Ask Claude" ? "bg-warning text-dark" : "bg-secondary") me-2">@headButton</span>
                }
                <span class="badge bg-light text-dark border me-2">@group.Count call@(group.Count == 1 ? "" : "s")</span>
                <span class="text-muted small">@headTime</span>
            </button>
        </h2>
        <div id="askGroup@(g)" class="accordion-collapse collapse @(expanded ? "show" : "")"
             data-bs-parent="#promptLogAccordion">
            <div class="accordion-body p-2">
@foreach (var e in group)
{
    var isDecode = e.Kind == "decode";
    var modelLabel = isDecode
        ? (e.Source == "ollama" ? "Local LLM" : e.Source == "claude_fallback" ? "Claude (fallback)" : "Claude")
        : (e.Model == "claude" ? "Claude" : "Local LLM");
    var isCloud = modelLabel.StartsWith("Claude");

    // Human-readable routing chain for decode entries, e.g.
    // "Local LLM ✗ → Claude (fallback) ✓" — shows exactly what happened.
    var routing = new List<(string Label, bool Ok, bool Cloud)>();
    if (isDecode)
    {
        var succeeded = e.Succeeded ?? true;
        if (e.Provider == "claude")
        {
            routing.Add(("Claude — direct", succeeded, true));
        }
        else if (e.Source == "claude_fallback")
        {
            routing.Add(("Local LLM", false, false));
            routing.Add(("Claude — fallback", true, true));
        }
        else if (succeeded)
        {
            routing.Add(("Local LLM", true, false));
        }
        else if (e.FallbackAttempted == true)
        {
            routing.Add(("Local LLM", false, false));
            routing.Add(("Claude — fallback", false, true));
        }
        else
        {
            routing.Add(("Local LLM", false, false));
        }
    }
    var noFallbackNote = isDecode && e.Provider != "claude" && (e.Succeeded ?? true) == false
                         && e.FallbackAttempted != true;

    <div class="card mb-2">
        <div class="card-header d-flex align-items-center flex-wrap gap-2 py-2">
            <span class="badge @(isDecode ? "bg-primary" : "bg-success")">@(isDecode ? "Decode" : "Summarize")</span>
            <span class="badge @(isCloud ? "bg-warning text-dark" : "bg-secondary")">@modelLabel</span>
            @if (isDecode && !string.IsNullOrEmpty(e.Provider))
            {
                <span class="text-muted small">via <strong>@(e.Provider == "claude" ? "Ask Claude" : "Ask Local AI")</strong></span>
            }
            @if (isDecode && !string.IsNullOrEmpty(e.Report))
            {
                <span class="text-muted small">report: <code>@e.Report</code></span>
            }
            @if (!isDecode && e.RowCount.HasValue)
            {
                <span class="text-muted small">@e.RowCount rows summarized (first 3 shown)</span>
            }
            <span class="ms-auto text-muted small">@LocalTime(e.Timestamp)</span>
        </div>
        <div class="card-body py-3">
            @if (isDecode)
            {
                <div class="mb-1"><span class="fw-semibold small text-uppercase text-muted">Question sent to the model</span></div>
                <code class="d-block p-2 bg-light border rounded">@e.SentQuestion</code>
                <p class="small text-muted mt-2 mb-0">@e.Note</p>
            }
            else
            {
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border border-danger-subtle rounded p-2 h-100">
                            <div class="fw-semibold small text-uppercase text-danger mb-2">Before — real data (never sent)</div>
                            <div class="small text-muted">Question</div>
                            <code class="d-block p-2 bg-light border rounded mb-2">@e.OriginalQuestion</code>
                            <div class="small text-muted">Rows</div>
                            @Html.Raw(RowsTable(e.OriginalRowsSample))
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border border-success-subtle rounded p-2 h-100">
                            <div class="fw-semibold small text-uppercase text-success mb-2">After — what the LLM received</div>
                            <div class="small text-muted">Question (scrubbed)</div>
                            <code class="d-block p-2 bg-light border rounded mb-2">@e.SentQuestion</code>
                            <div class="small text-muted">Rows (anonymized)</div>
                            @Html.Raw(RowsTable(e.SentRowsSample))
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
            </div>
        </div>
    </div>
}
</div>
