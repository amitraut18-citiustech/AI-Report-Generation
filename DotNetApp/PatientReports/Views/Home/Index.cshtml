@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">Patient Reports</h1>
    <p class="lead">Generate patient, transplant event, and clinical summary reports from the database.</p>
    <div class="mt-4 d-flex gap-2 justify-content-center">
        <a class="btn btn-primary btn-lg" asp-controller="Reports" asp-action="Index">Go to Reports</a>
        <a class="btn btn-success btn-lg" asp-controller="Reports" asp-action="HtmlReports">Generate HTML Report</a>
    </div>
    <p class="text-muted mt-3">
        <strong>Reports</strong> renders server-side (Razor). <strong>Generate HTML Report</strong> uses the
        plugin-generated HTML templates driven by the same .NET data &mdash; the SSRS-replacement demo.
    </p>
</div>
