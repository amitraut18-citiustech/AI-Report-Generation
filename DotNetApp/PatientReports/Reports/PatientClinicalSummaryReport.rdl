  <Code>
Public Function BmiCategory(ByVal bmi As Double) As String
  If bmi = 0 Then
    Return "N/A"
  ElseIf bmi &lt; 18.5 Then
    Return "Underweight"
  ElseIf bmi &lt; 25 Then
    Return "Normal"
  ElseIf bmi &lt; 30 Then
    Return "Overweight"
  Else
    Return "Obese"
  End If
End Function

Public Function RiskScore(ByVal age As Integer, ByVal inpatient As Boolean, ByVal outOfRangeLabs As Integer) As Integer
  Dim score As Integer = 0
  If age &gt;= 65 Then
    score = score + 2
  ElseIf age &gt;= 45 Then
    score = score + 1
  End If
  If inpatient Then
    score = score + 2
  End If
  score = score + outOfRangeLabs
  Return score
End Function
</Code>
