{
  "database": "HealthcareDB",
  "phiColumns": [
    { "table": "Patients", "column": "FirstName", "strategy": "pseudonymize" },
    { "table": "Patients", "column": "LastName", "strategy": "pseudonymize" },
    { "table": "Patients", "column": "DateOfBirth", "strategy": "age_range" },
