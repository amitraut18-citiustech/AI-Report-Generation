# Ollama (local LLM — default decode + summarize)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=30m

# Claude API — enables the "Ask Claude" button, automatic decode fallback, and
# summarize fallback. Read at startup: restart the brain after changing.
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=4096

# Charts in AI summaries (off by default — text-only keeps responses fast)
ENABLE_CHARTS=false

# DEMO/TESTING ONLY: force every local decode to fail so the Claude fallback
# fires deterministically (the "Claude (fallback)" banner on demand).
# Never enable outside demos.
FORCE_DECODE_FALLBACK=false

# Artifact Paths (Phase 1 outputs consumed by Phase 2)
REPORT_THOUGHTS_PATH=../ReportThoughts
HTML_REPORTS_PATH=../HTMLReportsFolder
SCHEMA_MAPPING_PATH=../DataSchemaMapping/schema-mapping.json
PHI_MARKERS_PATH=../DataSchemaMapping/phi-markers.json

# Brain Service (loopback only — no auth, handles PHI; port 8000 is blocked on the VDI)
BRAIN_HOST=127.0.0.1
BRAIN_PORT=8080
